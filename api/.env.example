WEB_PORT=4000
CLIENT_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgres://user:password@localhost:5432/dream_job
DATABASE_SSL=false
# For AWS RDS from EC2:
# DATABASE_URL=postgres://user:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/dream_job
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_CONNECT_TIMEOUT_MS=10000
WEB_SESSION_SECRET=change-me

WEB_USERNAME=admin@example.com
WEB_PASSWORD=change-me
# WEB_USERS=admin@example.com:change-me:admin,user@example.com:change-me:user

AWS_REGION=us-east-1
AWS_S3_BUCKET=your-private-resume-bucket
# Optional, useful for LocalStack or another local SQS-compatible endpoint.
