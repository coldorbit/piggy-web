{
  "name": "applypilot-api",
  "version": "1.0.0",
  "private": true,
  "description": "Express API for ApplyPilot.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "WEB_PORT=${WEB_PORT:-4000} node server.js",
    "start": "NODE_ENV=production WEB_PORT=${WEB_PORT:-4000} node server.js",
    "test": "node --test \"test/**/*.test.js\"",
    "check": "find . -path ./node_modules -prune -o -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/client-sqs": "^3.1054.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "imapflow": "^1.4.1",
    "mailparser": "^3.9.10",
    "pg": "^8.21.0",
    "sequelize": "^6.37.8"
  }
}
