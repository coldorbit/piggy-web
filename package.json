{
  "name": "applypilot",
  "version": "1.0.0",
  "private": true,
  "description": "ApplyPilot web workspace with separate React client, Express API, and tailoring worker apps.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter applypilot-api --filter applypilot-client dev",
    "build": "pnpm --filter applypilot-client build",
    "start": "pnpm --filter applypilot-api start",
    "check": "pnpm check:source-size && pnpm --recursive check",
    "check:source-size": "node scripts/check-source-file-size.mjs"
  },
  "workspaces": [
    "api",
    "client",
    "worker"
  ]
}
