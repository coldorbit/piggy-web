CLIENT_PORT=3000
API_PORT=4000
VITE_API_BASE_URL=http://localhost:4000

DB_PORT=5433
POSTGRES_USER=applypilot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=applypilot
DATABASE_URL=postgres://applypilot:change-me@localhost:5433/applypilot
DATABASE_SSL=false
# For AWS RDS from EC2:
# DATABASE_URL=postgres://user:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/applypilot
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_CONNECT_TIMEOUT_MS=10000
WEB_SESSION_SECRET=change-me
WEB_USERNAME=admin@example.com
WEB_PASSWORD=change-me
# WEB_USERS=admin@example.com:change-me:admin,user@example.com:change-me:user

AWS_REGION=us-east-1
AWS_S3_BUCKET=your-private-resume-bucket
# Optional, useful for LocalStack or another local SQS-compatible endpoint.
# AWS_SQS_ENDPOINT=http://localhost:4566
TAILORING_QUEUE_URL=

# Worker-only values. Put these on the tailoring worker EC2 host.
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_TIMEOUT_SECONDS=300
OPENAI_MODEL=gpt-5-mini
TAILORING_CONCURRENCY=4
TAILORING_MAX_ATTEMPTS=3
TAILORING_VISIBILITY_TIMEOUT_SECONDS=600
